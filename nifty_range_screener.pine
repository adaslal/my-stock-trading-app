//@version=6
indicator("Nifty Range & VAH Zone Screener", "VAH Zone Screener", overlay=true)

// ==========================================
// 1. INPUT PARAMETERS & WATCHLIST
// ==========================================

group_screener = "Watchlist Tickers"
ticker01 = input.symbol("NSE:RELIANCE", "Ticker 1", group=group_screener)
ticker02 = input.symbol("NSE:TCS", "Ticker 2", group=group_screener)
ticker03 = input.symbol("NSE:INFY", "Ticker 3", group=group_screener)
ticker04 = input.symbol("NSE:HDFCBANK", "Ticker 4", group=group_screener)
ticker05 = input.symbol("NSE:ICICIBANK", "Ticker 5", group=group_screener)
ticker06 = input.symbol("NSE:SBIN", "Ticker 6", group=group_screener)
ticker07 = input.symbol("NSE:BHARTIARTL", "Ticker 7", group=group_screener)
ticker08 = input.symbol("NSE:ITC", "Ticker 8", group=group_screener)
ticker09 = input.symbol("NSE:LTIM", "Ticker 9", group=group_screener)
ticker10 = input.symbol("NSE:AXISBANK", "Ticker 10", group=group_screener)
ticker11 = input.symbol("NSE:KOTAKBANK", "Ticker 11", group=group_screener)
ticker12 = input.symbol("NSE:LT", "Ticker 12", group=group_screener)
ticker13 = input.symbol("NSE:TATASTEEL", "Ticker 13", group=group_screener)
ticker14 = input.symbol("NSE:M&M", "Ticker 14", group=group_screener)
ticker15 = input.symbol("NSE:HINDUNILVR", "Ticker 15", group=group_screener)

group_vp = "Pivot Anchored Volume Profile (PAVP) Settings"
pivot_left = input.int(15, "Pivot Left Strength", minval=1, group=group_vp)
pivot_right = input.int(15, "Pivot Right Strength", minval=1, group=group_vp)
num_profile_levels = input.int(24, "Number of Profile Levels (Bins)", minval=5, maxval=100, group=group_vp)
value_area_pct = input.float(68.0, "Value Area Percentage (%)", minval=10.0, maxval=100.0, group=group_vp)
level_proximity = input.float(0.3, "Level Proximity Buffer (%)", minval=0.01, maxval=5.0, group=group_vp,
     tooltip="Proximity threshold to mark support/resistance alerts (as a percentage of price).")

group_arrow = "PAVP Zone Confirmation Settings (Bull & Bear)"
absorption_mult = input.float(1.5, "Absorption Sensitivity (x Avg Abs Cumulative Delta)", minval=0.5, maxval=5.0, group=group_arrow,
     tooltip="Lower = more signals, less selective. Compares net order-flow over the last few bars (cumulative single-bar OHLCV delta proxy, no intrabar data) against price's own move over that same stretch -- the same multi-day formula as pavpEngine.ts in your web app, so it can run across the whole watchlist at once. It is not the true intrabar CVD used in reliance_scalping_composite.pine.")

group_style = "Dashboard Style Settings"
table_pos = input.string("top_right", "Table Position", options=["top_right", "top_left", "bottom_right", "bottom_left"], group=group_style)

// Convert position string
get_position(pos) =>
    pos == "top_left" ? position.top_left :
     pos == "bottom_left" ? position.bottom_left :
     pos == "bottom_right" ? position.bottom_right :
     position.top_right

// ==========================================
// 2. CORE PAVP CALCULATION FUNCTION (per-symbol, runs inside request.security)
// ==========================================
// Ports the same pivot-anchored volume profile (POC/VAH/VAL) logic used in
// reliance_scalping_composite.pine, plus a lightweight single-bar delta proxy
// (same formula as pavpEngine.ts) to flag: close strictly between VAH and P High
// AND a bullish absorption read on that same bar.

calc_pavp_levels(p_left, p_right, n_levels, va_pct, abs_mult) =>
    p_high = ta.pivothigh(high, p_left, p_right)
    p_low = ta.pivotlow(low, p_left, p_right)

    var int last_pivot_index = 0
    if not na(p_high)
        last_pivot_index := bar_index - p_right
    if not na(p_low)
        last_pivot_index := bar_index - p_right

    var float val_price_hist = na
    var float vah_price_hist = na
    var float poc_price_hist = na
    var float p_high_hist = na
    var float p_low_hist = na

    if last_pivot_index > 0 and bar_index > last_bar_index - 3000
        // Cap lookback to 300 bars, same safeguard as the main indicator
        int bars_since_pivot = math.min(bar_index - last_pivot_index, 300)
        float max_p = high[bars_since_pivot]
        float min_p = low[bars_since_pivot]

        for i = 0 to bars_since_pivot
            max_p := math.max(max_p, high[i])
            min_p := math.min(min_p, low[i])

        float range_p = max_p - min_p
        float bin_size = range_p / n_levels

        float[] bin_vols = array.new_float(n_levels, 0.0)
        float total_vol = 0.0

        for i = 0 to bars_since_pivot
            float b_high = high[i]
            float b_low = low[i]
            float b_vol = volume[i]
            float b_range = math.max(b_high - b_low, 0.000001)
            total_vol += b_vol

            for k = 0 to n_levels - 1
                float bin_low = min_p + k * bin_size
                float bin_high = bin_low + bin_size
                float overlap_l = math.max(b_low, bin_low)
                float overlap_h = math.min(b_high, bin_high)
                if overlap_h > overlap_l
                    float overlap_frac = (overlap_h - overlap_l) / b_range
                    array.set(bin_vols, k, array.get(bin_vols, k) + b_vol * overlap_frac)

        float max_bin_vol = 0.0
        int poc_level = 0
        for k = 0 to n_levels - 1
            float vol_k = array.get(bin_vols, k)
            if vol_k > max_bin_vol
                max_bin_vol := vol_k
                poc_level := k

        float poc_price = min_p + (poc_level + 0.5) * bin_size

        float target_va_vol = total_vol * (va_pct / 100.0)
        float va_accum_vol = array.get(bin_vols, poc_level)
        int level_above = poc_level
        int level_below = poc_level

        while va_accum_vol < target_va_vol
            if level_below == 0 and level_above == n_levels - 1
                break

            float vol_above = 0.0
            if level_above < n_levels - 1
                vol_above := array.get(bin_vols, level_above + 1)

            float vol_below = 0.0
            if level_below > 0
                vol_below := array.get(bin_vols, level_below - 1)

            if vol_above == 0.0 and vol_below == 0.0
                break

            if vol_above >= vol_below
                va_accum_vol += vol_above
                level_above += 1
            else
                va_accum_vol += vol_below
                level_below -= 1

        val_price_hist := min_p + level_below * bin_size
        vah_price_hist := min_p + (level_above + 1) * bin_size
        poc_price_hist := poc_price
        p_high_hist := max_p
        p_low_hist := min_p

    // Single-bar delta proxy (no lower-timeframe pull) -- same formula as pavpEngine.ts,
    // chosen so this can run across the whole watchlist without hitting Pine's per-script
    // limits on request.security_lower_tf calls.
    float bar_range = math.max(high - low, 0.000001)
    float buy_pct = (close - low) / bar_range
    float bar_delta_proxy = volume * (2.0 * buy_pct - 1.0)

    // CVD Absorption (multi-day divergence). NOTE: a single bar's delta and "close vs. its
    // own midpoint" are mathematically the SAME signal (close > midpoint <=> buyPct > 0.5 <=>
    // delta > 0), so a same-bar check (delta very negative AND close > midpoint) can never be
    // true -- confirmed via backtest_explosive_signal.py returning zero real-data matches
    // across 132k signal-days. Absorption instead compares NET ORDER FLOW over a recent
    // window against the PRICE OUTCOME over that same window -- two independent quantities.
    // Keep absorption_window/absorption_baseline in sync with pavpEngine.ts / scan_real_market.py.
    int absorption_window = 5
    int absorption_baseline = 20
    float cum_delta = math.sum(bar_delta_proxy, absorption_window)
    float avg_abs_cum_delta = ta.sma(math.abs(cum_delta), absorption_baseline)
    float window_start_close = close[absorption_window - 1]
    float price_ret = window_start_close != 0 ? close / window_start_close - 1.0 : 0.0

    bool in_vah_phigh_zone = not na(vah_price_hist) and not na(p_high_hist) and close < p_high_hist and close > vah_price_hist
    // Bullish: heavy net SELLING over the last few bars, but price still held flat or rose
    // over that same stretch -- sellers got absorbed instead of pushing price down.
    bool bullish_delta_ok = cum_delta < -avg_abs_cum_delta * abs_mult and price_ret >= 0
    bool arrow_confirmed = in_vah_phigh_zone and bullish_delta_ok

    // Mirror: close strictly between P Low and VAL AND heavy net BUYING over the last few
    // bars that still failed to push price up (trapped buyers / breakdown confirmation).
    bool in_val_plow_zone = not na(val_price_hist) and not na(p_low_hist) and close < val_price_hist and close > p_low_hist
    bool bearish_delta_ok = cum_delta > avg_abs_cum_delta * abs_mult and price_ret <= 0
    bool arrow_bear_confirmed = in_val_plow_zone and bearish_delta_ok

    [close, p_high_hist, p_low_hist, vah_price_hist, val_price_hist, arrow_confirmed, arrow_bear_confirmed]

// ==========================================
// 3. MULTI-TICKER DATA SECURITY REQUESTS
// ==========================================

get_ticker_data(sym) =>
    [c, ph, pl, vah, val, arrow, bear_arrow] = request.security(sym, timeframe.period, calc_pavp_levels(pivot_left, pivot_right, num_profile_levels, value_area_pct, absorption_mult))
    [c, ph, pl, vah, val, arrow, bear_arrow]

[c01, ph01, pl01, vah01, val01, arrow01, bear01] = get_ticker_data(ticker01)
[c02, ph02, pl02, vah02, val02, arrow02, bear02] = get_ticker_data(ticker02)
[c03, ph03, pl03, vah03, val03, arrow03, bear03] = get_ticker_data(ticker03)
[c04, ph04, pl04, vah04, val04, arrow04, bear04] = get_ticker_data(ticker04)
[c05, ph05, pl05, vah05, val05, arrow05, bear05] = get_ticker_data(ticker05)
[c06, ph06, pl06, vah06, val06, arrow06, bear06] = get_ticker_data(ticker06)
[c07, ph07, pl07, vah07, val07, arrow07, bear07] = get_ticker_data(ticker07)
[c08, ph08, pl08, vah08, val08, arrow08, bear08] = get_ticker_data(ticker08)
[c09, ph09, pl09, vah09, val09, arrow09, bear09] = get_ticker_data(ticker09)
[c10, ph10, pl10, vah10, val10, arrow10, bear10] = get_ticker_data(ticker10)
[c11, ph11, pl11, vah11, val11, arrow11, bear11] = get_ticker_data(ticker11)
[c12, ph12, pl12, vah12, val12, arrow12, bear12] = get_ticker_data(ticker12)
[c13, ph13, pl13, vah13, val13, arrow13, bear13] = get_ticker_data(ticker13)
[c14, ph14, pl14, vah14, val14, arrow14, bear14] = get_ticker_data(ticker14)
[c15, ph15, pl15, vah15, val15, arrow15, bear15] = get_ticker_data(ticker15)

// ==========================================
// 4. SCREENER STATUS LOGIC
// ==========================================

get_screen_status(c, ph, pl, vah, val, arrow, bear_arrow, prox) =>
    if na(c) or na(ph) or na(pl)
        ["No Range", color.gray, color.white]
    else
        dist_l = (c - pl) / pl * 100.0
        dist_h = (ph - c) / ph * 100.0
        bool in_zone = not na(vah) and c < ph and c > vah
        bool in_bear_zone = not na(val) and c < val and c > pl

        if arrow
            ["🟣 VAH→P HIGH BULLISH CONFIRM", color.rgb(155, 38, 182), color.white]
        else if bear_arrow
            ["🟠 VAL→P LOW BEARISH CONFIRM", color.rgb(217, 119, 6), color.white]
        else if in_zone
            ["🔵 IN VAH→P HIGH ZONE", color.rgb(41, 128, 185), color.white]
        else if in_bear_zone
            ["🟤 IN VAL→P LOW ZONE", color.rgb(180, 83, 9), color.white]
        else if c <= pl or math.abs(dist_l) <= prox
            ["🟢 AT SUPPORT (P LOW)", color.rgb(46, 204, 113), color.white]
        else if dist_l <= prox * 3.0
            ["⏳ NEAR SUPPORT", color.rgb(39, 174, 96), color.white]
        else if c >= ph or math.abs(dist_h) <= prox
            ["🔴 AT RESISTANCE (P HIGH)", color.rgb(231, 76, 60), color.white]
        else if dist_h <= prox * 3.0
            ["⏳ NEAR RESISTANCE", color.rgb(192, 57, 43), color.white]
        else
            ["⚪ INSIDE RANGE", color.new(color.gray, 60), color.white]

// ==========================================
// 5. DASHBOARD RENDERING TABLE
// ==========================================

var table screener_tbl = table.new(get_position(table_pos), 7, 17, bgcolor=color.new(color.black, 20), border_color=color.gray, border_width=1)

update_table_row(row_idx, sym, c, ph, pl, vah, val, arrow, bear_arrow, prox) =>
    [status_text, bg_col, txt_col] = get_screen_status(c, ph, pl, vah, val, arrow, bear_arrow, prox)

    // Clean Ticker name (removes exchange prefix e.g. NSE:)
    clean_sym = str.contains(sym, ":") ? array.get(str.split(sym, ":"), 1) : sym

    color row_bg = arrow ? color.new(color.rgb(155, 38, 182), 70) : bear_arrow ? color.new(color.rgb(217, 119, 6), 70) : color.new(color.black, 40)

    table.cell(screener_tbl, 0, row_idx, clean_sym, text_color=color.white, text_size=size.small, bgcolor=row_bg)
    table.cell(screener_tbl, 1, row_idx, na(c) ? "-" : str.tostring(c, "#.00"), text_color=color.white, text_size=size.small, bgcolor=row_bg)
    table.cell(screener_tbl, 2, row_idx, na(pl) ? "-" : str.tostring(pl, "#.00"), text_color=color.rgb(46, 204, 113), text_size=size.small, bgcolor=row_bg)
    table.cell(screener_tbl, 3, row_idx, na(val) ? "-" : str.tostring(val, "#.00"), text_color=color.rgb(217, 119, 6), text_size=size.small, bgcolor=row_bg)
    table.cell(screener_tbl, 4, row_idx, na(vah) ? "-" : str.tostring(vah, "#.00"), text_color=color.rgb(0, 188, 212), text_size=size.small, bgcolor=row_bg)
    table.cell(screener_tbl, 5, row_idx, na(ph) ? "-" : str.tostring(ph, "#.00"), text_color=color.rgb(231, 76, 60), text_size=size.small, bgcolor=row_bg)
    table.cell(screener_tbl, 6, row_idx, status_text, text_color=txt_col, text_size=size.small, bgcolor=bg_col)

if barstate.islast
    // Header
    table.cell(screener_tbl, 0, 0, "NIFTY PAVP LONG/SHORT SCREENER", text_color=color.white, text_size=size.small, bgcolor=color.new(color.navy, 10))
    table.merge_cells(screener_tbl, 0, 0, 6, 0)

    // Column Headers
    table.cell(screener_tbl, 0, 1, "Ticker", text_color=color.gray, text_size=size.small, bgcolor=color.new(color.black, 30))
    table.cell(screener_tbl, 1, 1, "Price", text_color=color.gray, text_size=size.small, bgcolor=color.new(color.black, 30))
    table.cell(screener_tbl, 2, 1, "P Low", text_color=color.gray, text_size=size.small, bgcolor=color.new(color.black, 30))
    table.cell(screener_tbl, 3, 1, "VAL", text_color=color.gray, text_size=size.small, bgcolor=color.new(color.black, 30))
    table.cell(screener_tbl, 4, 1, "VAH", text_color=color.gray, text_size=size.small, bgcolor=color.new(color.black, 30))
    table.cell(screener_tbl, 5, 1, "P High", text_color=color.gray, text_size=size.small, bgcolor=color.new(color.black, 30))
    table.cell(screener_tbl, 6, 1, "Status", text_color=color.gray, text_size=size.small, bgcolor=color.new(color.black, 30))

    // Update data rows
    update_table_row(2, ticker01, c01, ph01, pl01, vah01, val01, arrow01, bear01, level_proximity)
    update_table_row(3, ticker02, c02, ph02, pl02, vah02, val02, arrow02, bear02, level_proximity)
    update_table_row(4, ticker03, c03, ph03, pl03, vah03, val03, arrow03, bear03, level_proximity)
    update_table_row(5, ticker04, c04, ph04, pl04, vah04, val04, arrow04, bear04, level_proximity)
    update_table_row(6, ticker05, c05, ph05, pl05, vah05, val05, arrow05, bear05, level_proximity)
    update_table_row(7, ticker06, c06, ph06, pl06, vah06, val06, arrow06, bear06, level_proximity)
    update_table_row(8, ticker07, c07, ph07, pl07, vah07, val07, arrow07, bear07, level_proximity)
    update_table_row(9, ticker08, c08, ph08, pl08, vah08, val08, arrow08, bear08, level_proximity)
    update_table_row(10, ticker09, c09, ph09, pl09, vah09, val09, arrow09, bear09, level_proximity)
    update_table_row(11, ticker10, c10, ph10, pl10, vah10, val10, arrow10, bear10, level_proximity)
    update_table_row(12, ticker11, c11, ph11, pl11, vah11, val11, arrow11, bear11, level_proximity)
    update_table_row(13, ticker12, c12, ph12, pl12, vah12, val12, arrow12, bear12, level_proximity)
    update_table_row(14, ticker13, c13, ph13, pl13, vah13, val13, arrow13, bear13, level_proximity)
    update_table_row(15, ticker14, c14, ph14, pl14, vah14, val14, arrow14, bear14, level_proximity)
    update_table_row(16, ticker15, c15, ph15, pl15, vah15, val15, arrow15, bear15, level_proximity)

// ==========================================
// 6. CROSS-TICKER ALERT
// ==========================================
// Fires (on whatever chart you host this script on) the moment ANY watchlist
// ticker's latest bar sits between VAH and P High with bullish absorption confirmed.
// Check the table to see which one(s).

bool any_ticker_confirmed = arrow01 or arrow02 or arrow03 or arrow04 or arrow05 or arrow06 or arrow07 or arrow08 or arrow09 or arrow10 or arrow11 or arrow12 or arrow13 or arrow14 or arrow15

alertcondition(any_ticker_confirmed, title="VAH→P High Bullish Confirm (Any Watchlist Ticker)",
     message="One or more watchlist tickers now has the latest candle between VAH and P High with bullish absorption confirmed. Check the VAH Zone Screener table for which one(s).")

// Mirror: fires the moment ANY watchlist ticker's latest bar sits between P Low
// and VAL with bearish absorption confirmed (trapped buyers / breakdown setup).
bool any_ticker_bear_confirmed = bear01 or bear02 or bear03 or bear04 or bear05 or bear06 or bear07 or bear08 or bear09 or bear10 or bear11 or bear12 or bear13 or bear14 or bear15

alertcondition(any_ticker_bear_confirmed, title="VAL→P Low Bearish Confirm (Any Watchlist Ticker)",
     message="One or more watchlist tickers now has the latest candle between P Low and VAL with bearish absorption confirmed. Check the VAH Zone Screener table for which one(s).")
